<clickhouse>
  <storage_configuration>
    <disks>
      <s3_backup>
        <type>s3</type>
        <endpoint>https://your-backup-endpoint</endpoint>
        <access_key_id>YOUR_KEY</access_key_id>
        <secret_access_key>YOUR_SECRET</secret_access_key>
        <bucket>your-backup-bucket</bucket>
      </s3_backup>
    </disks>
    <policies>
      <s3>
        <volumes>
          <main>
            <disk>s3_backup</disk>
          </main>
        </volumes>
      </s3>
    </policies>
  </storage_configuration>

  <backup>
    <allowed_path>/var/lib/clickhouse/backups/</allowed_path>
  </backup>
  <backups>
    <allowed_disk>s3_backup</allowed_disk>
  </backups>
</clickhouse>
